<Window x:Class="Coursework1.DebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Отладка системы" Height="400" Width="600"
        WindowStartupLocation="CenterScreen"
        Background="#F3F3F3"> <DockPanel>
        <Border DockPanel.Dock="Top" 
                Background="#F3F3F3" 
                BorderBrush="#DCDCDC" 
                BorderThickness="0,0,0,1" 
                Padding="5">
            <StackPanel Orientation="Horizontal">
                <Button Content="Очистить" 
                        Click="Clear_Click" 
                        Padding="10,2" 
                        Margin="5,0"/>
                <Separator Margin="5,0" Background="#DCDCDC"/>
                <CheckBox x:Name="AutoScrollCheck" 
                          Content="Автопрокрутка" 
                          IsChecked="True" 
                          VerticalAlignment="Center" 
                          Margin="5,0"/>
            </StackPanel>
        </Border>

        <Border Margin="10" 
                Background="White" 
                BorderBrush="#DCDCDC" 
                BorderThickness="1">
            <TextBox x:Name="LogBox"
                     BorderThickness="0"
                     FontFamily="Consolas" 
                     FontSize="12"
                     Foreground="#333333"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Padding="5"/>
        </Border>
    </DockPanel>
</Window>