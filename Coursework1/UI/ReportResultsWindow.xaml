<Window x:Class="Coursework1.UI.ReportResultsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Отчёт" Height="500" Width="1000"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <Style x:Key="CenterAlignmentStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <DataGrid x:Name="ReportDataGrid"
                  ItemsSource="{Binding ReportItems}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#E0E0E0"
                  AlternatingRowBackground="#F9F9F9"
                  RowHeaderWidth="0"
                  BorderThickness="0"
                  Background="White"
                  ColumnWidth="*"> <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Height" Value="35"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    <Setter Property="BorderBrush" Value="#DCDCDC"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="ВУ" 
                                    Binding="{Binding License}" 
                                    Width="Auto"
                                    MinWidth="100"/>

                <DataGridTextColumn Header="ФИО нарушителя" 
                                    Binding="{Binding FullName}" 
                                    Width="2*"/>

                <DataGridTextColumn Header="Категория" 
                                    Binding="{Binding Categories}" 
                                    Width="Auto"
                                    MinWidth="70"
                                    ElementStyle="{StaticResource CenterAlignmentStyle}"/>

                <DataGridTextColumn Header="Нарушение" 
                                    Binding="{Binding Article}" 
                                    Width="3*"/>

                <DataGridTextColumn Header="Сумма (₽)" 
                                    Binding="{Binding Price, StringFormat={}{0:N0}}" 
                                    Width="Auto"
                                    MinWidth="80"
                                    ElementStyle="{StaticResource CenterAlignmentStyle}"/>

                <DataGridTextColumn Header="Дата нарушения" 
                                    Binding="{Binding Date}" 
                                    Width="Auto"
                                    MinWidth="120"
                                    ElementStyle="{StaticResource CenterAlignmentStyle}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>