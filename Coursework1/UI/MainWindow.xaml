<Window x:Class="Coursework1.UI.MainWindow"
        Language="ru-RU"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ГИБДД" Height="600" Width="1100"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Водители">
                <MenuItem Header="Импорт" Click="ImportDrivers_Click"/>
                <MenuItem Header="Экспорт" Click="ExportDriversButton_Click"/>
                <MenuItem Header="Добавить" Click="AddDriver_Click"/>
                <MenuItem Header="Удалить выбранное" Click="RemoveDrivers_Click" />
                <MenuItem Header="Задать размер ХТ" Click="SetHashTableCapacity_Click" />
            </MenuItem>
            <MenuItem Header="Штрафы">
                <MenuItem Header="Импорт" Click="ImportFines_Click"/>
                <MenuItem Header="Экспорт" Click="ExportFinesButton_Click"/>
                <MenuItem Header="Добавить" Click="AddFine_Click" />
                <MenuItem Header="Удалить выбранное" Click="RemoveFines_Click" />
            </MenuItem>
            <MenuItem Header="Отчёт" Click="ReportCreate_Click" />
        </Menu>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>

            <StatusBarItem Grid.Column="0">
                <TextBlock x:Name="StatusText" Text="Здесь могла быть ваша реклама" Foreground="Gray" FontSize="11"/>
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="300" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" MinWidth="300" />
            </Grid.ColumnDefinitions>

            <GroupBox Header="Водители" Grid.Column="0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#F3F3F3" BorderBrush="#DCDCDC" BorderThickness="0,0,0,1" Margin="0,0,0,5">
                        <Grid Margin="5">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Поиск по ВУ:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBox x:Name="SearchInDrivers" Width="150" VerticalContentAlignment="Center"/>
                                <Button Content="Найти" Margin="5,0" Padding="10,2" Click="FindDriver_Click"/>
                            </StackPanel>
                            
                            <Button Content="Debug (HT)" 
                                    HorizontalAlignment="Right"
                                    Background="Transparent" 
                                    BorderThickness="0"
                                    FontSize="10"
                                    Click="DebugDrivers_Click"
                                    Cursor="Hand"/>
                        </Grid>
                    </Border>
                    
                    <DataGrid x:Name="DriversGrid" ItemsSource="{Binding Drivers}" 
                              CanUserResizeColumns="False" 
                              CanUserResizeRows="False"
                              CanUserSortColumns="False"
                              CanUserReorderColumns="False"
                              AutoGenerateColumns="False" 
                              IsReadOnly="True"
                              SelectionMode="Extended"
                              Background="White"
                              ColumnHeaderHeight="30">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Серия/Номер ВУ" Binding="{Binding License}" Width="Auto"/>
                            <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="*"/>
                            <DataGridTextColumn Header="Категории" Binding="{Binding Categories}" Width="Auto"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </GroupBox>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="Transparent" Cursor="SizeWE"/>

            <GroupBox Header="Штрафы" Grid.Column="2">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#F3F3F3" BorderBrush="#DCDCDC" BorderThickness="0,0,0,1" Margin="0,0,0,5">
                        <Grid Margin="5">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Поиск по ВУ:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBox x:Name="SearchInFines" Width="150" VerticalContentAlignment="Center"/>
                                <Button Click="FindFines_Click" Content="Найти" Margin="5,0" Padding="10,2"/>
                            </StackPanel>

                            <Button Content="Debug (RBT)" 
                                    HorizontalAlignment="Right"
                                    Background="Transparent" 
                                    BorderThickness="0"
                                    FontSize="10"
                                    Click="DebugFines_Click"
                                    Cursor="Hand"/>
                        </Grid>
                    </Border>

                    <DataGrid x:Name="FinesGrid" ItemsSource="{Binding Fines}" 
                              CanUserResizeColumns="False" 
                              CanUserResizeRows="False"
                              CanUserSortColumns="False"
                              CanUserReorderColumns="False"
                              AutoGenerateColumns="False" 
                              IsReadOnly="True"
                              SelectionMode="Extended"
                              Background="White">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Серия/Номер ВУ" Binding="{Binding Fine.License}" Width="Auto"/>
                            <DataGridTextColumn Header="Нарушение" Binding="{Binding Fine.Article}" Width="*"/>
                            <DataGridTextColumn Header="Сумма" Binding="{Binding Fine.Price}" Width="Auto"/>
                            <DataGridTextColumn Header="Дата нарушения" Binding="{Binding Fine.Date, StringFormat=\{0:dd.MM.yyyy\}}" Width="Auto"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>