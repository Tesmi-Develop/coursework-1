<Window x:Class="Coursework1.UI.AddFineWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление штрафа" Height="400" Width="450" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    <RowDefinition Height="Auto"/> </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Данные ВУ:" Grid.Row="0" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox x:Name="VuBox" Grid.Row="0" Grid.Column="1" Margin="10,5" Padding="3" 
                 HorizontalAlignment="Stretch"/>

        <TextBlock Text="Дата:" Grid.Row="1" VerticalAlignment="Center" Margin="0,5"/>
        <DatePicker x:Name="ViolationDatePicker" Grid.Row="1" Grid.Column="1" Margin="10,5" 
                    HorizontalAlignment="Stretch"/>

        <TextBlock Text="Сумма (₽):" Grid.Row="2" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox x:Name="AmountBox" Grid.Row="2" Grid.Column="1" Margin="10,5" Padding="3" 
                 HorizontalAlignment="Stretch"
                 PreviewTextInput="NumberValidationTextBox"/>

        <TextBlock Text="Нарушение:" Grid.Row="3" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox x:Name="ViolationTitleBox" 
                 Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" 
                 Margin="0,5" Padding="5"
                 HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                 TextWrapping="Wrap" AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"/>

        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Отмена" Width="80" IsCancel="True" Margin="0,0,10,0"/>
            <Button Content="Добавить" Width="100" IsDefault="True" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>