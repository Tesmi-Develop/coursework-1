<Window x:Class="Coursework1.UI.AddRecordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление водителя" Height="350" Width="400" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    <RowDefinition Height="Auto"/> </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Фамилия:" Grid.Row="0" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox x:Name="LastNameBox" Grid.Row="0" Grid.Column="1" Margin="10,5" Padding="3"/>

        <TextBlock Text="Имя:" Grid.Row="1" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox x:Name="FirstNameBox" Grid.Row="1" Grid.Column="1" Margin="10,5" Padding="3"/>

        <TextBlock Text="Отчество:" Grid.Row="2" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox x:Name="MiddleNameBox" Grid.Row="2" Grid.Column="1" Margin="10,5" Padding="3"/>

        <TextBlock Text="Данные ВУ:" Grid.Row="3" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox x:Name="VuBox" Grid.Row="3" Grid.Column="1" Margin="10,5" Padding="3"/>

        <TextBlock Text="Категории:" Grid.Row="4" VerticalAlignment="Top" Margin="0,10"/>
        <ItemsControl ItemsSource="{Binding AllCategories}" Grid.Row="4" Grid.Column="1" Margin="10,5">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <CheckBox Content="{Binding}" 
                              Margin="0,0,10,5" 
                              Tag="{Binding}"
                              Checked="CheckBox_Changed"
                              Unchecked="CheckBox_Changed"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отмена" Width="80" IsCancel="True" Margin="0,0,10,0"/>
            <Button Content="Сохранить" Width="100" IsDefault="True" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>