<Window x:Class="Coursework1.UI.ErrorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ошибка" Height="180" Width="380" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="25">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="*"/>    </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>      <RowDefinition Height="Auto"/>   </Grid.RowDefinitions>

        <Grid Grid.Column="0" VerticalAlignment="Center">
            <Ellipse Width="42" Height="42" Fill="#FFDADA"/>
            <TextBlock Text="✕" Foreground="#D32F2F" FontSize="22" 
                       HorizontalAlignment="Center" VerticalAlignment="Center" 
                       FontWeight="Bold" Margin="0,0,0,2"/>
        </Grid>

        <TextBlock x:Name="MessageText" 
                   Grid.Column="1" 
                   TextWrapping="Wrap" 
                   Margin="20,0,0,0" 
                   VerticalAlignment="Center" 
                   FontSize="13"
                   LineHeight="18"
                   Text="Текст ошибки по умолчанию"/>

        <Button Content="ОК" 
                Grid.Row="1" Grid.ColumnSpan="2" 
                HorizontalAlignment="Right" 
                Width="90" Height="28"
                Margin="0,15,0,0"
                IsDefault="True" 
                Click="Close_Click"/>
    </Grid>
</Window>